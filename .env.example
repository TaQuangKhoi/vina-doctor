# Copy this file to .env and fill in your values before running docker compose.

# ── AI Engine ─────────────────────────────────────────────────────────────────
# Alibaba Cloud DashScope API key for Qwen2-Audio
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ── Backend ───────────────────────────────────────────────────────────────────
# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret

# DATABASE_URL and AUDIO_STORAGE_PATH are overridden in docker-compose.yml
# to use the named volume. Set these only for local (non-Docker) development:
# DATABASE_URL=sqlite+aiosqlite:///./vina_doctor.db
# AUDIO_STORAGE_PATH=./audio_uploads
